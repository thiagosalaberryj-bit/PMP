# Servidor
PORT=3000
BASE_URL=http://localhost:3000

# MySQL - Cambia estos valores
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=pmp
# Solo para Aiven (requiere SSL). Para MySQL local borrar o dejar false
DB_SSL=true

# JWT - Cambia esto por una clave secreta
JWT_SECRET=change-this-to-a-random-secret-key

# Mercado Pago OAuth - Crear una app en https://developers.mercadopago.com/
MP_CLIENT_ID=123456789
MP_CLIENT_SECRET=your-client-secret-here

# Mercado Pago - Access Token (solo para webhook, modo test o produccion)
MP_ACCESS_TOKEN=TEST-123456789-abcdefghijklmnopqrstuvwxyz
